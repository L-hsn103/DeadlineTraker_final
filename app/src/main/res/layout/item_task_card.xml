<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/bg_task_card"
    android:padding="13dp"
    android:layout_marginBottom="10dp">

    <!-- Colored dot -->
    <View
        android:id="@+id/taskDot"
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:layout_marginEnd="11dp"
        android:layout_marginTop="4dp"
        android:layout_gravity="top"
        android:background="@drawable/bg_dot_red" />

    <!-- Text info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvTaskName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Task Name"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:fontFamily="@font/sora" />

        <TextView
            android:id="@+id/tvTaskMeta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="📅 Date — Details"
            android:textSize="11sp"
            android:textColor="@color/text_secondary" />
    </LinearLayout>

    <!-- Tag -->
    <TextView
        android:id="@+id/tvTaskTag"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CT"
        android:textSize="10sp"
        android:textStyle="bold"
        android:textColor="@color/ct_color"
        android:background="@drawable/bg_tag_ct"
        android:paddingLeft="9dp" android:paddingRight="9dp"
        android:paddingTop="3dp" android:paddingBottom="3dp" />
</LinearLayout>