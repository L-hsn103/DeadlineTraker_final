<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="TextStyle">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="TextStyle.Title">
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextStyle.Subtitle">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="Button">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:padding">14dp</item>
        <item name="android:background">@drawable/bg_button_green</item>
    </style>

    <style name="Button.Purple">
        <item name="android:background">@drawable/bg_button_purple</item>
    </style>

    <style name="Card">
        <item name="android:background">@drawable/bg_task_card</item>
        <item name="android:padding">13dp</item>
    </style>

    <style name="Card.Stat">
        <item name="android:padding">12dp</item>
        <item name="android:background">@drawable/bg_stat_done</item>
    </style>

</resources>