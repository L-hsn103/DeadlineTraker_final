<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/bg_task_card"
    android:padding="14dp"
    android:layout_marginBottom="10dp"
    android:gravity="center_vertical">

    <!-- Icon circle -->
    <FrameLayout android:id="@+id/notifIconBg"
        android:layout_width="40dp" android:layout_height="40dp"
        android:background="@drawable/bg_stat_done"
        android:layout_marginEnd="12dp">
        <TextView android:id="@+id/notifIcon"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_gravity="center" android:text="📋" android:textSize="18sp" />
    </FrameLayout>

    <!-- Text info -->
    <LinearLayout
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical">

        <TextView android:id="@+id/notifTitle"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Task Title" android:textSize="13sp" android:textStyle="bold"
            android:textColor="@color/text_primary" android:fontFamily="@font/sora" />

        <TextView android:id="@+id/notifDesc"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="3dp" android:text="Due: Apr 12"
            android:textSize="11sp" android:textColor="@color/text_secondary" />

        <TextView android:id="@+id/notifTime"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="3dp" android:text="1 day remaining"
            android:textSize="10sp" android:textColor="@color/urgent_red_light" />
    </LinearLayout>

    <!-- Unread dot -->
    <View android:id="@+id/unreadDot"
        android:layout_width="8dp" android:layout_height="8dp"
        android:background="@drawable/bg_notif_badge"
        android:visibility="visible" />

</LinearLayout>