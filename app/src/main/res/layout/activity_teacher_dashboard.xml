<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_teacher_primary">

    <!-- ══ Bottom Navigation — declared FIRST ══ -->
    <LinearLayout
        android:id="@+id/bottomNavTeacher"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:background="@color/bg_teacher_nav"
        android:paddingBottom="8dp"
        android:elevation="8dp">

        <LinearLayout
            android:id="@+id/tNavHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/bg_nav_active_purple">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🏠" android:textSize="20sp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Home" android:textSize="10sp"
                android:textColor="@color/purple_light" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tNavCalendar"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="📅" android:textSize="20sp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Calendar" android:textSize="10sp"
                android:textColor="@color/text_secondary" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tNavNotif"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🔔" android:textSize="20sp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Notifs" android:textSize="10sp"
                android:textColor="@color/text_secondary" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tNavSettings"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="⚙️" android:textSize="20sp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Settings" android:textSize="10sp"
                android:textColor="@color/text_secondary" />
        </LinearLayout>
    </LinearLayout>

    <!-- ══ FAB: Add Task — declared SECOND so it floats above nav ══ -->
    <FrameLayout
        android:id="@+id/fabAddTask"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_above="@id/bottomNavTeacher"
        android:layout_alignParentEnd="true"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_button_purple"
        android:elevation="10dp"
        android:clickable="true"
        android:focusable="true">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="+"
            android:textSize="28sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />
    </FrameLayout>

    <!-- ══ ScrollView sits ABOVE the bottom nav ══ -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottomNavTeacher"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Purple Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_header_gradient_purple"
                android:paddingLeft="20dp"
                android:paddingRight="20dp"
                android:paddingTop="40dp"
                android:paddingBottom="14dp">

                <!-- User row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="18dp">

                    <de.hdodenhof.circleimageview.CircleImageView
                        android:id="@+id/ivAvatar"
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:src="@drawable/bg_avatar_purple" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="10dp">

                        <TextView
                            android:id="@+id/tvUserName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Teacher"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:fontFamily="@font/sora" />

                        <TextView
                            android:id="@+id/tvUserRole"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Teacher — CSE Dept."
                            android:textSize="11sp"
                            android:textColor="@color/text_secondary" />
                    </LinearLayout>

                    <FrameLayout
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:background="@drawable/bg_notif_btn">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="🔔"
                            android:textSize="18sp" />
                        <View
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:layout_gravity="top|end"
                            android:layout_marginTop="6dp"
                            android:layout_marginEnd="6dp"
                            android:background="@drawable/bg_notif_badge" />
                    </FrameLayout>
                </LinearLayout>

                <!-- Stats Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@drawable/bg_stat_ct"
                        android:padding="11dp"
                        android:layout_marginEnd="4dp">
                        <TextView
                            android:id="@+id/tvCtCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="#93C5FD"
                            android:fontFamily="@font/sora" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Classes"
                            android:textSize="10sp"
                            android:textColor="@color/text_secondary" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@drawable/bg_stat_asgn"
                        android:padding="11dp"
                        android:layout_marginEnd="4dp">
                        <TextView
                            android:id="@+id/tvAsgnCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="#C4B5FD"
                            android:fontFamily="@font/sora" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Assignments"
                            android:textSize="10sp"
                            android:textColor="@color/text_secondary" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@drawable/bg_stat_quiz"
                        android:padding="11dp">
                        <TextView
                            android:id="@+id/tvQuizCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="#FCD34D"
                            android:fontFamily="@font/sora" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Quizzes"
                            android:textSize="10sp"
                            android:textColor="@color/text_secondary" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Task List -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingLeft="20dp"
                android:paddingRight="20dp"
                android:paddingBottom="80dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MY TASKS"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08"
                    android:fontFamily="@font/sora"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="10dp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerTasks"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:clipToPadding="false"
                    android:paddingBottom="16dp" />

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

</RelativeLayout>