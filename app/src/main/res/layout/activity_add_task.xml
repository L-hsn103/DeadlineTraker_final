<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_teacher_primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="22dp"
        android:paddingTop="44dp"
        android:paddingBottom="90dp">

        <!-- Back -->
        <TextView android:id="@+id/tvBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="←" android:textSize="20sp"
            android:textColor="#66FFFFFF"
            android:layout_marginBottom="16dp" />

        <TextView android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Post a Task"
            android:textSize="20sp" android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:fontFamily="@font/sora" />

        <TextView android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="22dp"
            android:text="Fill in task details for your batch"
            android:textSize="12sp"
            android:textColor="@color/text_secondary" />

        <!-- Task Title -->
        <TextView android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TASK TITLE" android:textSize="10sp"
            android:textColor="@color/text_label"
            android:textAllCaps="true" android:letterSpacing="0.08"
            android:layout_marginBottom="6dp" />
        <EditText android:id="@+id/etTaskTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="e.g. CT-1 Exam — Chapter 1–3"
            android:background="@drawable/bg_input_field"
            android:padding="13dp" android:textSize="13sp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_muted"
            android:layout_marginBottom="14dp" />

        <!-- Date & Time -->
        <TextView android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DATE &amp; TIME" android:textSize="10sp"
            android:textColor="@color/text_label"
            android:textAllCaps="true" android:letterSpacing="0.08"
            android:layout_marginBottom="6dp" />
        <EditText android:id="@+id/etDateTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Tap to pick date and time"
            android:background="@drawable/bg_input_field"
            android:padding="13dp" android:textSize="13sp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_muted"
            android:focusable="false"
            android:layout_marginBottom="14dp" />

        <!-- Department (auto-filled, locked) -->
        <TextView android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DEPARTMENT" android:textSize="10sp"
            android:textColor="@color/text_label"
            android:textAllCaps="true" android:letterSpacing="0.08"
            android:layout_marginBottom="6dp" />
        <EditText android:id="@+id/etDepartment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Auto-filled from your profile"
            android:background="@drawable/bg_input_field"
            android:padding="13dp" android:textSize="13sp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_muted"
            android:layout_marginBottom="14dp" />

        <!-- Batch — teacher types freely -->
        <TextView android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BATCH(ES)" android:textSize="10sp"
            android:textColor="@color/text_label"
            android:textAllCaps="true" android:letterSpacing="0.08"
            android:layout_marginBottom="6dp" />

        <!-- Hint below label -->
        <TextView android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Type batch numbers separated by commas"
            android:textSize="11sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="6dp" />

        <EditText android:id="@+id/etBatches"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="e.g. 2022, 2023, 2024"
            android:background="@drawable/bg_input_field"
            android:padding="13dp" android:textSize="13sp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_muted"
            android:inputType="text"
            android:layout_marginBottom="14dp" />

        <!-- Type chips -->
        <TextView android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TYPE" android:textSize="10sp"
            android:textColor="@color/text_label"
            android:textAllCaps="true" android:letterSpacing="0.08"
            android:layout_marginBottom="6dp" />

        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="14dp">

            <TextView android:id="@+id/chipCT"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CT" android:textSize="12sp"
                android:textColor="#93C5FD"
                android:background="@drawable/bg_chip_ct_sel"
                android:paddingLeft="14dp" android:paddingRight="14dp"
                android:paddingTop="7dp" android:paddingBottom="7dp"
                android:layout_marginEnd="8dp" />

            <TextView android:id="@+id/chipAssignment"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Assignment" android:textSize="12sp"
                android:textColor="#66FFFFFF"
                android:background="@drawable/bg_chip_default"
                android:paddingLeft="14dp" android:paddingRight="14dp"
                android:paddingTop="7dp" android:paddingBottom="7dp"
                android:layout_marginEnd="8dp" />

            <TextView android:id="@+id/chipQuiz"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quiz" android:textSize="12sp"
                android:textColor="#66FFFFFF"
                android:background="@drawable/bg_chip_default"
                android:paddingLeft="14dp" android:paddingRight="14dp"
                android:paddingTop="7dp" android:paddingBottom="7dp" />
        </LinearLayout>

        <!-- Description -->
        <TextView android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DESCRIPTION" android:textSize="10sp"
            android:textColor="@color/text_label"
            android:textAllCaps="true" android:letterSpacing="0.08"
            android:layout_marginBottom="6dp" />
        <EditText android:id="@+id/etDescription"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:hint="e.g. Topics covered, what to bring..."
            android:background="@drawable/bg_input_field"
            android:padding="13dp" android:textSize="13sp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_muted"
            android:gravity="top"
            android:inputType="textMultiLine"
            android:layout_marginBottom="14dp" />

        <!-- Attach File -->
        <TextView android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ATTACHMENT (OPTIONAL)"
            android:textSize="10sp"
            android:textColor="@color/text_label"
            android:textAllCaps="true" android:letterSpacing="0.08"
            android:layout_marginBottom="6dp" />

        <LinearLayout android:id="@+id/attachFileBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_input_field"
            android:padding="13dp"
            android:layout_marginBottom="8dp">

            <TextView android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📎"
                android:textSize="18sp"
                android:layout_marginEnd="10dp" />

            <TextView android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Attach PDF or Image"
                android:textSize="13sp"
                android:textColor="@color/text_secondary" />
        </LinearLayout>

        <!-- Selected file name -->
        <TextView android:id="@+id/tvSelectedFile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="12sp"
            android:textColor="@color/green_light"
            android:layout_marginBottom="14dp"
            android:visibility="gone" />

        <!-- Warning note -->
        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_stat_asgn"
            android:padding="13dp"
            android:layout_marginBottom="16dp">
            <TextView android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚠️" android:textSize="13sp"
                android:layout_marginEnd="8dp" />
            <TextView android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Only Teachers can post tasks. CR can view and share but cannot post."
                android:textSize="11sp"
                android:textColor="@color/text_label"
                android:lineSpacingMultiplier="1.5" />
        </LinearLayout>

        <!-- Progress bar -->
        <ProgressBar android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginBottom="12dp"
            android:indeterminateTint="@color/purple_primary"
            android:visibility="gone" />

        <!-- Post button -->
        <Button android:id="@+id/btnPostTask"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Post Task"
            android:textSize="14sp"
            android:textColor="@color/text_primary"
            android:fontFamily="@font/sora"
            android:textStyle="bold"
            android:background="@drawable/bg_button_purple"
            android:padding="14dp" />

    </LinearLayout>
</ScrollView>