<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_task_card"
    android:padding="14dp"
    android:layout_marginBottom="10dp">

    <!-- Top row: icon + title + unread dot -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <FrameLayout android:id="@+id/notifIconBg"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_stat_asgn"
            android:layout_marginEnd="12dp">
            <TextView android:id="@+id/notifIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="📋"
                android:textSize="18sp" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView android:id="@+id/notifTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CT-1 Exam"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:fontFamily="@font/sora" />

            <TextView android:id="@+id/notifMeta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="📅 Apr 12 — 10:00 AM"
                android:textSize="11sp"
                android:textColor="@color/text_secondary" />
        </LinearLayout>

        <View android:id="@+id/unreadDot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/bg_notif_badge"
            android:visibility="visible" />
    </LinearLayout>

    <!-- Bottom row: batch tags + countdown -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="10dp">

        <TextView android:id="@+id/notifBatches"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Batch 2022, 2023"
            android:textSize="10sp"
            android:textColor="#66FFFFFF"
            android:background="@drawable/bg_chip_default"
            android:paddingLeft="10dp" android:paddingRight="10dp"
            android:paddingTop="3dp" android:paddingBottom="3dp"
            android:layout_marginEnd="8dp" />

        <TextView android:id="@+id/notifType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CT"
            android:textSize="10sp"
            android:textColor="@color/ct_color"
            android:background="@drawable/bg_tag_ct"
            android:paddingLeft="10dp" android:paddingRight="10dp"
            android:paddingTop="3dp" android:paddingBottom="3dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="end"
            android:id="@+id/notifCountdown"
            android:text="2 days remaining"
            android:textSize="10sp"
            android:textColor="@color/green_light" />
    </LinearLayout>

    <!-- Conflict warning (shown only when conflict exists) -->
    <LinearLayout android:id="@+id/conflictBanner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/bg_conflict_banner"
        android:padding="8dp"
        android:layout_marginTop="10dp"
        android:visibility="gone">

        <TextView android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚠️ "
            android:textSize="12sp" />

        <TextView android:id="@+id/conflictText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Another teacher posted on the same date"
            android:textSize="11sp"
            android:textColor="@color/conflict_text"
            android:lineSpacingMultiplier="1.4" />
    </LinearLayout>

</LinearLayout>