<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="22dp"
        android:paddingTop="60dp"
        android:paddingBottom="40dp">

        <TextView android:id="@+id/tvBack"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="←" android:textSize="20sp" android:textColor="#66FFFFFF"
            android:layout_marginBottom="18dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="📚  Teacher / CR"
            android:textSize="11sp" android:textColor="#C084FC"
            android:background="@drawable/bg_badge_purple"
            android:paddingLeft="11dp" android:paddingRight="11dp"
            android:paddingTop="4dp" android:paddingBottom="4dp"
            android:layout_marginBottom="14dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Create your account" android:textSize="22sp" android:textStyle="bold"
            android:textColor="@color/text_primary" android:fontFamily="@font/sora" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="5dp" android:layout_marginBottom="18dp"
            android:text="Teacher or Class Representative"
            android:textSize="12sp" android:textColor="@color/text_secondary" />

        <!-- Tab switcher -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_subtab_container"
            android:padding="3dp"
            android:layout_marginBottom="16dp">

            <Button android:id="@+id/tabTeacher"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Teacher"
                android:textSize="12sp" android:textColor="#C084FC"
                android:background="@drawable/bg_subtab_active"
                android:padding="7dp" />

            <Button android:id="@+id/tabCR"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Class Rep (CR)"
                android:textSize="12sp" android:textColor="#66FFFFFF"
                android:background="@android:color/transparent"
                android:padding="7dp" />
        </LinearLayout>

        <!-- Teacher fields -->
        <LinearLayout android:id="@+id/layoutTeacher"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="FULL NAME" android:textSize="10sp" android:textColor="@color/text_label"
                android:textAllCaps="true" android:letterSpacing="0.08" android:layout_marginBottom="6dp" />
            <EditText android:id="@+id/etTeacherName"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:hint="e.g. Dr. Karim Hossain" android:background="@drawable/bg_input_field"
                android:padding="13dp" android:textSize="13sp" android:textColor="@color/text_primary"
                android:textColorHint="@color/text_muted" android:layout_marginBottom="14dp" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="TEACHER ID" android:textSize="10sp" android:textColor="@color/text_label"
                android:textAllCaps="true" android:letterSpacing="0.08" android:layout_marginBottom="6dp" />
            <EditText android:id="@+id/etTeacherId"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:hint="e.g. TCH-0021" android:background="@drawable/bg_input_field"
                android:padding="13dp" android:textSize="13sp" android:textColor="@color/text_primary"
                android:textColorHint="@color/text_muted" android:layout_marginBottom="14dp" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="DEPARTMENT" android:textSize="10sp" android:textColor="@color/text_label"
                android:textAllCaps="true" android:letterSpacing="0.08" android:layout_marginBottom="6dp" />
            <EditText android:id="@+id/etTeacherDept"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:hint="e.g. CSE" android:background="@drawable/bg_input_field"
                android:padding="13dp" android:textSize="13sp" android:textColor="@color/text_primary"
                android:textColorHint="@color/text_muted" android:layout_marginBottom="14dp" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="GMAIL (FOR VERIFICATION)" android:textSize="10sp"
                android:textColor="@color/text_label" android:textAllCaps="true"
                android:letterSpacing="0.08" android:layout_marginBottom="6dp" />
            <EditText android:id="@+id/etTeacherEmail"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:hint="you@gmail.com" android:background="@drawable/bg_input_field"
                android:padding="13dp" android:textSize="13sp" android:textColor="@color/text_primary"
                android:textColorHint="@color/text_muted" android:layout_marginBottom="14dp"
                android:inputType="textEmailAddress" />

            <!-- ✅ NEW: Teacher Password -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="PASSWORD" android:textSize="10sp" android:textColor="@color/text_label"
                android:textAllCaps="true" android:letterSpacing="0.08" android:layout_marginBottom="6dp" />
            <EditText android:id="@+id/etTeacherPassword"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:hint="••••••••" android:background="@drawable/bg_input_field"
                android:padding="13dp" android:textSize="13sp" android:textColor="@color/text_primary"
                android:textColorHint="@color/text_muted" android:layout_marginBottom="14dp"
                android:inputType="textPassword" />

        </LinearLayout>

        <!-- CR fields (hidden by default) -->
        <LinearLayout android:id="@+id/layoutCR"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="FULL NAME" android:textSize="10sp" android:textColor="@color/text_label"
                android:textAllCaps="true" android:letterSpacing="0.08" android:layout_marginBottom="6dp" />
            <EditText android:id="@+id/etCRName"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:hint="e.g. Nusrat Jahan" android:background="@drawable/bg_input_field"
                android:padding="13dp" android:textSize="13sp" android:textColor="@color/text_primary"
                android:textColorHint="@color/text_muted" android:layout_marginBottom="14dp" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="CR / STUDENT ID" android:textSize="10sp" android:textColor="@color/text_label"
                android:textAllCaps="true" android:letterSpacing="0.08" android:layout_marginBottom="6dp" />
            <EditText android:id="@+id/etCRId"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:hint="e.g. STU-2022-0001" android:background="@drawable/bg_input_field"
                android:padding="13dp" android:textSize="13sp" android:textColor="@color/text_primary"
                android:textColorHint="@color/text_muted" android:layout_marginBottom="14dp" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="DEPARTMENT" android:textSize="10sp" android:textColor="@color/text_label"
                android:textAllCaps="true" android:letterSpacing="0.08" android:layout_marginBottom="6dp" />
            <EditText android:id="@+id/etCRDept"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:hint="e.g. CSE" android:background="@drawable/bg_input_field"
                android:padding="13dp" android:textSize="13sp" android:textColor="@color/text_primary"
                android:textColorHint="@color/text_muted" android:layout_marginBottom="14dp" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="BATCH" android:textSize="10sp" android:textColor="@color/text_label"
                android:textAllCaps="true" android:letterSpacing="0.08" android:layout_marginBottom="6dp" />
            <EditText android:id="@+id/etCRBatch"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:hint="e.g. 2022" android:background="@drawable/bg_input_field"
                android:padding="13dp" android:textSize="13sp" android:textColor="@color/text_primary"
                android:textColorHint="@color/text_muted" android:layout_marginBottom="14dp"
                android:inputType="number" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="GMAIL (FOR VERIFICATION)" android:textSize="10sp"
                android:textColor="@color/text_label" android:textAllCaps="true"
                android:letterSpacing="0.08" android:layout_marginBottom="6dp" />
            <EditText android:id="@+id/etCREmail"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:hint="you@gmail.com" android:background="@drawable/bg_input_field"
                android:padding="13dp" android:textSize="13sp" android:textColor="@color/text_primary"
                android:textColorHint="@color/text_muted" android:layout_marginBottom="14dp"
                android:inputType="textEmailAddress" />

            <!-- ✅ NEW: CR Password -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="PASSWORD" android:textSize="10sp" android:textColor="@color/text_label"
                android:textAllCaps="true" android:letterSpacing="0.08" android:layout_marginBottom="6dp" />
            <EditText android:id="@+id/etCRPassword"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:hint="••••••••" android:background="@drawable/bg_input_field"
                android:padding="13dp" android:textSize="13sp" android:textColor="@color/text_primary"
                android:textColorHint="@color/text_muted" android:layout_marginBottom="14dp"
                android:inputType="textPassword" />

        </LinearLayout>

        <!-- Verification note -->
        <LinearLayout
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:background="@drawable/bg_info_green"
            android:padding="13dp" android:layout_marginBottom="16dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="✉️" android:textSize="14sp" android:layout_marginEnd="9dp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="A verification link will be sent to your Gmail before activation."
                android:textSize="11sp" android:textColor="@color/text_label"
                android:lineSpacingMultiplier="1.5" />
        </LinearLayout>

        <!-- ✅ NEW: ProgressBar -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginBottom="12dp"
            android:indeterminateTint="@color/purple_medium"
            android:visibility="gone" />

        <Button android:id="@+id/btnRegister"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Register as Teacher"
            android:textSize="14sp" android:textColor="@color/text_primary"
            android:fontFamily="@font/sora" android:textStyle="bold"
            android:background="@drawable/bg_button_purple" android:padding="14dp" />

    </LinearLayout>
</ScrollView>